@page "/admin/dashboard"
@layout AdminLayout

<div class="mb-10 mt-2 border-b-2 border-on-background pb-6">
    <h2 class="font-display-lg text-[40px] xl:text-[48px] text-on-background mb-2 font-black tracking-tight">Visão Geral</h2>
    <p class="font-body-lg text-on-surface-variant text-xl">Gerencie as operações diárias e o inventário da biblioteca.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
    <div class="bg-surface-container-lowest border-2 border-on-background neo-shadow p-6 flex items-start justify-between">
        <div>
            <p class="font-label-md text-on-surface-variant mb-1 uppercase tracking-wider">Total de Livros</p>
            <p class="font-display-lg text-on-surface text-4xl font-black">12.450</p>
        </div>
        <div class="bg-primary-container p-3 border-2 border-on-background">
            <span class="material-symbols-outlined text-on-primary-container text-3xl">library_books</span>
        </div>
    </div>
    
    <div class="bg-surface-container-lowest border-2 border-on-background neo-shadow p-6 flex items-start justify-between">
        <div>
            <p class="font-label-md text-on-surface-variant mb-1 uppercase tracking-wider">Empréstimos Ativos</p>
            <p class="font-display-lg text-on-surface text-4xl font-black">842</p>
        </div>
        <div class="bg-secondary-container p-3 border-2 border-on-background">
            <span class="material-symbols-outlined text-on-secondary-container text-3xl">book</span>
        </div>
    </div>
    
    <div class="bg-[#ffdad6] border-2 border-on-background neo-shadow p-6 flex items-start justify-between">
        <div>
            <p class="font-label-md text-[#93000a] mb-1 uppercase tracking-wider">Atrasados</p>
            <p class="font-display-lg text-[#93000a] text-4xl font-black">37</p>
        </div>
        <div class="bg-surface-container-lowest p-3 border-2 border-on-background">
            <span class="material-symbols-outlined text-error text-3xl">warning</span>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8 pb-12">
    
    <div class="xl:col-span-2 bg-surface-container-lowest border-2 border-on-background neo-shadow p-8 flex flex-col h-full">
        <div class="flex justify-between items-center mb-8">
            <h3 class="font-headline-md text-2xl font-bold text-on-surface">Gerenciamento de Inventário</h3>
            <button class="bg-primary-container text-on-surface border-2 border-on-background px-6 py-3 font-label-md uppercase neo-shadow hover:bg-secondary-container transition-all flex items-center gap-2 font-bold">
                <span class="material-symbols-outlined text-xl">add</span> Novo Livro
            </button>
        </div>
        
        <div class="overflow-x-auto flex-grow">
            <table class="w-full text-left border-collapse min-w-[600px]">
                <thead>
                    <tr class="border-b-2 border-on-background">
                        <th class="py-4 px-2 font-label-md text-on-surface uppercase tracking-wider">Título</th>
                        <th class="py-4 px-2 font-label-md text-on-surface uppercase tracking-wider">Autor</th>
                        <th class="py-4 px-2 font-label-md text-on-surface uppercase tracking-wider">Status</th>
                        <th class="py-4 px-2 font-label-md text-on-surface uppercase tracking-wider text-right">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Inventory)
                    {
                        <tr class="border-b-2 border-on-background hover:bg-surface-variant transition-colors group">
                            <td class="py-5 px-2 font-body-lg text-on-surface font-bold">@item.Title</td>
                            <td class="py-5 px-2 font-body-md text-on-surface-variant text-lg">@item.Author</td>
                            <td class="py-5 px-2">
                                @if (item.Status == BookStatus.Available)
                                {
                                    <span class="inline-block border-2 border-on-background bg-surface-bright px-3 py-1 font-label-sm font-bold uppercase neo-shadow">Disponível</span>
                                }
                                else if (item.Status == BookStatus.Loaned)
                                {
                                    <span class="inline-block bg-primary-container border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase neo-shadow">Emprestado</span>
                                }
                                else
                                {
                                    <span class="inline-block bg-[#ffdad6] text-[#93000a] border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase neo-shadow">Atrasado</span>
                                }
                            </td>
                            <td class="py-5 px-2 text-right">
                                <div class="flex items-center justify-end gap-3 opacity-100 xl:opacity-0 xl:group-hover:opacity-100 transition-opacity">
                                    <a href="/admin/inventory/@item.Id" aria-label="Editar Livro" class="p-2 border-2 border-on-background hover:bg-primary-container transition-colors inline-flex">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                    </a>
                                    <button aria-label="Excluir" class="p-2 border-2 border-on-background hover:bg-[#ffdad6] text-error transition-colors">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="xl:col-span-1 bg-surface-container-lowest border-2 border-on-background neo-shadow p-8 flex flex-col h-full">
        <div class="flex justify-between items-center mb-8">
            <h3 class="font-headline-md text-2xl font-bold text-on-surface">Usuários Recentes</h3>
            <span class="material-symbols-outlined text-on-surface-variant cursor-pointer">more_horiz</span>
        </div>

        <div class="flex flex-col gap-4 flex-grow">
            <div class="flex items-center gap-4 border-b-2 border-on-background pb-4">
                <div class="w-12 h-12 rounded-full border-2 border-on-background bg-primary-container flex items-center justify-center font-bold text-on-background">JD</div>
                <div class="flex-1">
                    <p class="font-body-md font-bold text-on-surface">Jane Doe</p>
                    <p class="font-label-sm text-on-surface-variant">jane@example.com</p>
                </div>
            </div>

            <div class="flex items-center gap-4 border-b-2 border-on-background pb-4">
                <div class="w-12 h-12 rounded-full border-2 border-on-background bg-secondary-container flex items-center justify-center font-bold text-on-background">AS</div>
                <div class="flex-1">
                    <p class="font-body-md font-bold text-on-surface">Alex Smith</p>
                    <p class="font-label-sm text-on-surface-variant">alex.s@example.com</p>
                </div>
                <div class="w-3 h-3 bg-error rounded-full border-2 border-on-background"></div>
            </div>

            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full border-2 border-on-background bg-[#ccc460] flex items-center justify-center font-bold text-on-background">RJ</div>
                <div class="flex-1">
                    <p class="font-body-md font-bold text-on-surface">Robert Jones</p>
                    <p class="font-label-sm text-on-surface-variant">rob.j@example.com</p>
                </div>
            </div>
        </div>

        <button class="w-full mt-8 bg-surface-container-lowest border-2 border-on-background px-4 py-3 font-label-md font-bold neo-shadow hover:bg-surface-variant transition-all uppercase tracking-wider">
            Ver Todos os Usuários
        </button>
    </div>

</div>

@code {
    // Adicionamos a propriedade 'Id' para que o botão 'edit' saiba para qual página ir.
    private List<InventoryItem> Inventory = new()
    {
        new InventoryItem { Id = 1, Title = "Neuromancer", Author = "William Gibson", Status = BookStatus.Available },
        new InventoryItem { Id = 2, Title = "Snow Crash", Author = "Neal Stephenson", Status = BookStatus.Loaned },
        new InventoryItem { Id = 3, Title = "A Mão Esquerda da Escuridão", Author = "Ursula K. Le Guin", Status = BookStatus.Available },
        new InventoryItem { Id = 4, Title = "1984", Author = "George Orwell", Status = BookStatus.Overdue }
    };

    public class InventoryItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public BookStatus Status { get; set; }
    }

    public enum BookStatus
    {
        Available,
        Loaned,
        Overdue
    }
}