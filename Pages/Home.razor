@page "/"
@layout MainLayout

@* Adicionamos um pt-12 (padding-top) para "abaixar" o conteúdo conforme solicitado *@
<div class="flex flex-col gap-12 pt-12">

    <header class="flex flex-col gap-8">
        <div class="border-b-4 border-on-background pb-6">
            <h1 class="font-display-lg text-[48px] xl:text-[56px] text-on-background mb-2 font-black tracking-tighter uppercase leading-none">
                EXPLORE NOSSO ACERVO!
            </h1>
            <p class="font-body-lg text-on-surface-variant text-xl uppercase font-bold tracking-widest text-xs italic">
                Seleções curadas do nosso repositório digital de engenharia.
            </p>
        </div>

        @* <div class="w-full relative">
            <input class="w-full bg-white border-2 border-on-background py-5 pl-14 pr-6 font-body-lg text-on-surface neo-shadow focus:outline-none" placeholder="BUSCAR POR TÍTULO, AUTOR OU GÊNERO..." />
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface text-3xl">search</span>
        </div> *@

        <div class="flex flex-wrap gap-4">
            <button class="px-6 py-2 border-2 border-on-background bg-primary-container font-label-md font-black uppercase tracking-wider neo-shadow hover:bg-secondary-container transition-all">
                [TUDO]
            </button>
            @foreach (var tag in Tags)
            {
                <button class="px-6 py-2 border-2 border-on-background bg-surface-container-lowest font-label-md font-bold uppercase neo-shadow hover:bg-secondary-container transition-all">
                    [@tag]
                </button>
            }
        </div>
    </header>

    <section class="flex flex-col gap-6">
        <h2 class="font-display-lg text-3xl uppercase border-b-4 border-on-background pb-2 w-max pr-8 font-black italic">
            Tendências
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var book in FeaturedBooks)
            {
                <article class="bg-primary-fixed border-2 border-on-background neo-shadow flex flex-col h-full group relative overflow-hidden">
                    @* Área da Capa com Mix-Blend e Grayscale *@
                    <div class="h-48 border-b-2 border-on-background overflow-hidden relative bg-white">
                        <img src="@book.CoverUrl" class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80 group-hover:scale-105 transition-transform duration-500" />
                    </div>
                    
                    @* Info do Livro (Caixa interna) *@
                    <div class="p-6 flex flex-col flex-grow justify-between gap-4 bg-surface-container-lowest m-2 border-2 border-on-background">
                        <div>
                            <h3 class="font-headline-lg text-2xl uppercase line-clamp-2 mb-1 font-black leading-tight">@book.Title</h3>
                            <p class="font-label-sm text-on-surface-variant font-bold uppercase text-xs">@book.Author</p>
                        </div>
                        
                        <button @onclick="() => AbrirCheckout(book.Id)" class="mt-4 w-full bg-primary-container border-2 border-on-background py-3 font-label-md font-bold uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                            EMPRÉSTIMO
                        </button>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="flex flex-col gap-6 pb-16">
        <h2 class="font-display-lg text-3xl uppercase border-b-4 border-on-background pb-2 w-max pr-8 font-black italic">
            Explorar Acervo
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
            @foreach (var book in AllBooks)
            {
                <article class="bg-surface-container-lowest border-2 border-on-background neo-shadow flex flex-col h-full group">
                    <div class="h-56 border-b-2 border-on-background bg-surface-variant overflow-hidden">
                        <img src="@book.CoverUrl" class="w-full h-full object-cover grayscale mix-blend-luminosity opacity-90 group-hover:scale-110 transition-transform" />
                    </div>
                    <div class="p-4 flex flex-col flex-grow justify-between">
                        <div class="mb-4">
                            <h4 class="font-headline-md text-base uppercase leading-tight font-black line-clamp-2">@book.Title</h4>
                            <p class="font-label-md text-[10px] text-on-surface-variant uppercase mt-1 font-bold">@book.Author</p>
                        </div>
                        <button class="w-full bg-primary-container border-2 border-on-background py-2 font-label-md text-xs font-bold uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">
                            EMPRÉSTIMO
                        </button>
                    </div>
                </article>
            }
        </div>
        
        <div class="flex justify-center mt-12">
            <button class="px-12 py-4 border-4 border-on-background bg-white font-headline-md text-2xl font-black uppercase neo-shadow hover:bg-secondary-container hover:-translate-x-1 hover:-translate-y-1 transition-all">
                Carregar Mais
            </button>
        </div>
    </section>
</div>

@if (selectedBookId.HasValue)
{
    <BookCheckout BookId="selectedBookId.Value" OnClose="FecharCheckout" />
}

@code {
    private int? selectedBookId;
    private List<string> Tags = new() { "SCI-FI", "ARCHITECTURE", "TECH", "DESIGN" };

    private List<BookBrief> FeaturedBooks = new() {
        new BookBrief { Title = "Neuromancer", Author = "William Gibson", CoverUrl = "https://images.unsplash.com/photo-1618557161755-9ef633e88c0a?w=400" },
        new BookBrief { Title = "Form & Space", Author = "Francis D.K.", CoverUrl = "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=400" },
        new BookBrief { Title = "Hackers", Author = "Steven Levy", CoverUrl = "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=400" }
    };

    private List<BookBrief> AllBooks = new() {
        new BookBrief { Title = "Dune", Author = "Frank Herbert", CoverUrl = "https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?w=300" },
        new BookBrief { Title = "Grid Systems", Author = "J. Müller-Brockmann", CoverUrl = "https://images.unsplash.com/photo-1507721999472-8ed4421c4af2?w=300" },
        new BookBrief { Title = "Snow Crash", Author = "Neal Stephenson", CoverUrl = "https://images.unsplash.com/photo-1518770660439-4636190af475?w=300" },
        new BookBrief { Title = "Typography", Author = "Emil Ruder", CoverUrl = "https://images.unsplash.com/photo-1561070791-2526d30994b5?w=300" },
        new BookBrief { Title = "Simulacra", Author = "Jean Baudrillard", CoverUrl = "https://images.unsplash.com/photo-1516259762381-22954d7d3ad2?w=300" }
    };

    private void AbrirCheckout(int id) {
        selectedBookId = id;
    }

    private void FecharCheckout() {
        selectedBookId = null;
    }

    public class BookBrief {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public string CoverUrl { get; set; } = "";
    }
}