<header class="bg-surface-container-lowest w-full border-b-2 border-on-background flex justify-center h-24 sticky top-0 z-50">
    <div class="container mx-auto max-w-container-max flex justify-between items-center h-full px-margin-mobile xl:px-0 gap-8">
        
        <div class="flex items-center h-full w-[260px] shrink-0 border-r-0 xl:border-r-2 border-transparent">
            <span class="font-headline-lg text-[20px] font-black text-on-surface tracking-tight uppercase leading-tight">
                Projeto de Engenharia<br />de Software
            </span>
        </div>

        <div class="flex-1 relative hidden md:block max-w-2xl">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-2xl">search</span>
            <input class="w-full pl-14 pr-6 py-4 bg-surface-container-lowest border-2 border-on-background focus:outline-none focus:ring-2 focus:ring-on-background focus:ring-offset-2 transition-shadow font-body-lg text-body-lg placeholder:text-on-surface-variant neo-shadow"
                   placeholder="Pesquisar por título, autor ou ISBN no acervo..." type="text" />
        </div>
    
        <div class="flex items-center gap-4 shrink-0">
            <button class="flex items-center justify-center p-3 border-2 border-on-background bg-surface-container-lowest neo-shadow hover:bg-secondary-container transition-all">
                <span class="material-symbols-outlined">notifications</span>
            </button>
            <button class="flex items-center justify-center p-3 border-2 border-on-background bg-surface-container-lowest neo-shadow hover:bg-secondary-container transition-all">
                <span class="material-symbols-outlined">account_circle</span>
            </button>
            <button class="hidden lg:block bg-surface-container-lowest border-2 border-on-background px-6 py-3 font-label-md text-label-md font-bold neo-shadow hover:bg-primary-container transition-all text-on-surface">
                Painel do Usuário
            </button>
        </div>
    </div>
</header>