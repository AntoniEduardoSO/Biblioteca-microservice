@page "/my-loans"
@layout MainLayout
@using BibliotecaMicroservice.Models

<div class="flex flex-col gap-12 pt-4">

    <header class="mb-4 border-b-4 border-on-background pb-6">
        <h1 class="font-display-lg text-[48px] xl:text-[56px] font-black uppercase text-on-background tracking-tighter leading-none">
            Meus Empréstimos
        </h1>
        <p class="font-body-lg text-xl text-on-surface-variant mt-2 font-bold uppercase tracking-widest text-xs italic">
            Gerencie suas leituras atuais e consulte seu histórico.
        </p>
    </header>

    <div class="flex flex-col gap-16 max-w-[900px] pb-12">
        
        <!-- BLOCO 1: VIGENTES -->
        <section class="flex flex-col gap-6">
            <h2 class="font-headline-lg text-2xl font-black uppercase border-b-4 border-on-background pb-2 border-dashed">
                Vigentes (@MyActiveLoans.Count)
            </h2>
            
            <div class="flex flex-col gap-8">
                @foreach (var loan in MyActiveLoans)
                {
                    <article class="flex flex-col md:flex-row bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] group">
                        <div class="w-full md:w-48 h-64 md:h-auto border-b-2 md:border-b-0 md:border-r-2 border-on-background shrink-0 bg-surface-variant p-4 flex items-center justify-center overflow-hidden">
                            <img alt="Capa de @loan.BookTitle" class="w-full h-full object-cover border-2 border-on-background shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] group-hover:scale-105 transition-transform duration-500" src="@loan.CoverUrl"/>
                        </div>
                        
                        <div class="p-6 flex flex-col md:flex-row flex-1 justify-between gap-6">
                            <div class="flex flex-col justify-center">
                                <div class="inline-block bg-on-background text-white font-label-sm text-xs uppercase px-2 py-1 border-2 border-on-background mb-3 self-start">
                                    [@(loan.Type == LoanType.Online ? "ONLINE" : "PRESENCIAL")]
                                </div>
                                <h3 class="font-headline-md text-3xl font-bold text-on-background uppercase mb-1">@loan.BookTitle</h3>
                                <p class="font-body-md text-on-surface-variant font-bold uppercase text-sm">@loan.BookAuthor</p>
                            </div>
                            
                            <div class="flex flex-col justify-center items-start md:items-end gap-4 border-t-2 md:border-t-0 md:border-l-2 border-dashed border-on-background pt-4 md:pt-0 md:pl-6">
                                @if (loan.IsOverdue)
                                {
                                    <div class="bg-[#ffdad6] text-[#93000a] font-label-md font-bold px-3 py-1 border-2 border-on-background uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                        ATRASADO - @((DateTime.Now - loan.DueDate).Days) DIAS
                                    </div>
                                }
                                else
                                {
                                    <div class="bg-[#ccc460] text-on-background font-label-md font-bold px-3 py-1 border-2 border-on-background uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                        Devolução em @((loan.DueDate - DateTime.Now).Days) Dias
                                    </div>
                                }
                                
                                <div class="flex flex-wrap gap-3 mt-auto">
                                    <button class="px-4 py-2 bg-surface-bright border-2 border-on-background shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] font-label-md text-xs uppercase font-bold hover:bg-secondary-container hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">
                                        Renovar
                                    </button>
                                    
                                    <button @onclick="() => DevolverLivro(loan)" class="px-4 py-2 bg-[#ffdad6] text-[#93000a] border-2 border-on-background shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] font-label-md text-xs uppercase font-bold hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[1px] hover:translate-y-[1px] transition-all">
                                        Devolver
                                    </button>
                                    
                                    @if (loan.Type == LoanType.Online)
                                    {
                                        <button @onclick="() => AbrirLeitor(loan)" class="px-4 py-2 bg-primary-container border-2 border-on-background shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] font-label-md text-xs uppercase font-bold hover:bg-secondary-container hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">menu_book</span> Ler Agora
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </section>

        <!-- BLOCO 2: HISTÓRICO -->
        <section class="flex flex-col gap-6">
            <h2 class="font-headline-lg text-2xl font-black uppercase border-b-4 border-on-background pb-2 border-dashed text-on-surface-variant">
                Histórico de Empréstimos
            </h2>
            
            <div class="flex flex-col gap-6">
                @foreach (var loan in PastLoans)
                {
                    <article class="flex flex-col md:flex-row bg-[#e7e0e7] border-2 border-on-background shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] opacity-80 hover:opacity-100 transition-opacity group">
                        <div class="w-full md:w-32 h-48 md:h-auto border-b-2 md:border-b-0 md:border-r-2 border-on-background shrink-0 bg-surface-variant flex items-center justify-center overflow-hidden">
                            <img alt="Capa de @loan.BookTitle" class="w-full h-full object-cover grayscale mix-blend-multiply opacity-60 group-hover:scale-105 transition-transform duration-500" src="@loan.CoverUrl"/>
                        </div>
                        
                        <div class="p-4 md:p-6 flex flex-col md:flex-row flex-1 justify-between gap-6">
                            <div class="flex flex-col justify-center">
                                <div class="inline-block bg-[#1d1b1f] text-white font-label-sm text-[10px] uppercase px-2 py-1 border-2 border-on-background mb-3 self-start">
                                    [@(loan.Type == LoanType.Online ? "ONLINE" : "PRESENCIAL")]
                                </div>
                                <h3 class="font-headline-md text-2xl font-black text-on-background uppercase mb-1 line-through decoration-2 decoration-on-background">@loan.BookTitle</h3>
                                <p class="font-body-md text-on-surface-variant font-bold uppercase text-sm">@loan.BookAuthor</p>
                            </div>
                            
                            <div class="flex flex-col justify-center items-start md:items-end gap-2 border-t-2 md:border-t-0 md:border-l-2 border-dashed border-outline pt-4 md:pt-0 md:pl-6">
                                <div class="bg-white text-on-background font-label-md font-bold px-3 py-1 border-2 border-on-background uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                    Devolvido em: @loan.ReturnedDate?.ToString("dd/MM/yyyy")
                                </div>
                                <div class="mt-auto">
                                    <span class="material-symbols-outlined font-black text-on-surface-variant text-4xl">check_circle</span>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
            
            <!-- Botão Carregar Mais -->
            <button class="mt-4 bg-white text-on-background border-4 border-on-background px-8 py-4 font-headline-md text-xl font-black uppercase shadow-[6px_6px_0px_0px_#1d1b1f] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[4px_4px_0px_0px_#1d1b1f] transition-all self-center">
                Carregar Mais (5)
            </button>
        </section>

    </div>
</div>

@if (readingLoan != null)
{
    <BibliotecaMicroservice.Layout.PdfReader Book="readingLoan" OnClose="FecharLeitor" />
}

