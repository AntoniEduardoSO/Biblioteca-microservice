@page "/admin/users"
@layout AdminLayout
@using BibliotecaMicroservice.Models

<div class="mb-10 mt-2 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b-2 border-on-background pb-6">
    <div>
        <h2 class="font-display-lg text-[40px] xl:text-[48px] font-black text-on-background uppercase tracking-tighter leading-none">
            Gestão de Leitores
        </h2>
        <p class="font-body-lg text-xl text-on-surface-variant mt-2 border-l-4 border-[#d1b3ff] pl-4 font-bold uppercase tracking-wider text-sm">
            Navegue, filtre e gerencie os usuários cadastrados.
        </p>
    </div>
    <button class="bg-[#d1b3ff] text-on-background border-4 border-on-background px-6 py-3 font-headline-md text-lg font-black uppercase tracking-wider shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[4px] hover:translate-y-[4px] hover:bg-[#ffb7c5] transition-all flex items-center gap-2 w-fit">
        <span class="material-symbols-outlined font-black">person_add</span>
        Novo Leitor
    </button>
</div>

<!-- Barra de Filtros -->
<div class="bg-white border-4 border-on-background p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] mb-10 flex flex-col lg:flex-row gap-6 items-center">
    <div class="relative w-full lg:w-1/3">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant font-bold text-2xl">search</span>
        <input type="text" placeholder="Buscar por nome ou email..." 
               class="w-full bg-[#f8f2f8] border-4 border-on-background py-4 pl-14 pr-4 font-body-lg font-bold text-on-background focus:outline-none focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:-translate-y-1 focus:-translate-x-1 transition-all" />
    </div>
    
    <div class="flex flex-wrap gap-4 w-full lg:w-auto items-center">
        <span class="font-label-md text-sm font-black uppercase tracking-wider text-on-surface-variant mr-2">Status:</span>
        
        <label class="flex items-center gap-2 cursor-pointer group">
            <input type="radio" name="status_filter" class="peer sr-only" checked />
            <div class="px-6 py-3 border-4 border-on-background bg-white font-label-md font-bold text-sm uppercase peer-checked:bg-[#ccc460] peer-checked:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] peer-checked:-translate-x-1 peer-checked:-translate-y-1 transition-all">
                Todos
            </div>
        </label>
        <label class="flex items-center gap-2 cursor-pointer group">
            <input type="radio" name="status_filter" class="peer sr-only" />
            <div class="px-6 py-3 border-4 border-on-background bg-white font-label-md font-bold text-sm uppercase peer-checked:bg-[#d1b3ff] peer-checked:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] peer-checked:-translate-x-1 peer-checked:-translate-y-1 transition-all">
                Ativos
            </div>
        </label>
        <label class="flex items-center gap-2 cursor-pointer group">
            <input type="radio" name="status_filter" class="peer sr-only" />
            <div class="px-6 py-3 border-4 border-on-background bg-white font-label-md font-bold text-sm uppercase peer-checked:bg-[#ffdad6] peer-checked:text-[#93000a] peer-checked:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] peer-checked:-translate-x-1 peer-checked:-translate-y-1 transition-all">
                Bloqueados
            </div>
        </label>
    </div>
</div>

<!-- Grid de Usuários -->
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 mb-12">
    @foreach (var user in DisplayedUsers)
    {
        <article class="group bg-surface-bright border-4 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[4px] hover:translate-y-[4px] transition-all relative overflow-hidden flex flex-col h-full">
            <div class="p-6 flex-grow">
                <div class="flex justify-between items-start mb-6">
                    <div class="w-20 h-20 border-4 border-on-background overflow-hidden bg-[#d1b3ff] shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                        {
                            <img src="@user.AvatarUrl" alt="Avatar" class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all" />
                        }
                        else
                        {
                            <span class="font-display-lg text-4xl font-black text-on-background">@user.Initials</span>
                        }
                    </div>
                    
                    @if (user.IsActive)
                    {
                        <span class="inline-flex items-center gap-2 bg-[#ccc460] text-on-background border-4 border-on-background px-3 py-1 font-label-md font-bold text-xs uppercase tracking-wide shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                            <span class="w-2 h-2 rounded-full bg-on-background"></span> Ativo
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-2 bg-[#ffdad6] text-[#93000a] border-4 border-on-background px-3 py-1 font-label-md font-bold text-xs uppercase tracking-wide shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                            <span class="material-symbols-outlined text-[14px] font-black">block</span> Bloqueado
                        </span>
                    }
                </div>
                
                <h3 class="font-headline-lg text-3xl font-black text-on-background mb-1 uppercase">@user.Name</h3>
                <p class="font-body-md font-bold text-on-surface-variant flex items-center gap-2 mb-6 border-b-4 border-on-background border-dashed pb-4">
                    <span class="material-symbols-outlined text-lg">mail</span> @user.Email
                </p>
                
                <div class="grid grid-cols-2 gap-4 mt-auto">
                    <div>
                        <p class="font-label-sm text-xs text-on-surface-variant font-bold uppercase mb-1">Membro Desde</p>
                        <p class="font-headline-md text-xl font-black uppercase">@user.JoinedDate.ToString("MMM yyyy")</p>
                    </div>
                    <div>
                        <p class="font-label-sm text-xs text-on-surface-variant font-bold uppercase mb-1">Livros Lidos</p>
                        <p class="font-headline-md text-xl font-black uppercase">@user.BooksRead</p>
                    </div>
                </div>
            </div>
            
            <!-- Ações Flutuantes (Aparecem no Hover) -->
            <div class="absolute inset-x-0 bottom-0 bg-white border-t-4 border-on-background p-4 flex gap-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-10">
                <button @onclick="() => AbrirModal(user)" class="flex-1 bg-surface-variant border-4 border-on-background py-3 font-label-md font-black text-sm uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-[#d1b3ff] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Editar</button>
                @if (user.IsActive)
                {
                    <button class="flex-1 bg-[#ffdad6] text-[#93000a] border-4 border-on-background py-3 font-label-md font-black text-sm uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Bloquear</button>
                }
                else
                {
                    <button class="flex-1 bg-[#ccc460] text-on-background border-4 border-on-background py-3 font-label-md font-black text-sm uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Desbloquear</button>
                }
            </div>
        </article>
    }
</div>

<!-- Paginação -->
<div class="flex justify-center items-center gap-4 mt-4">
    <button @onclick="PreviousPage" disabled="@(currentPage == 1)" class="w-12 h-12 flex items-center justify-center border-4 border-on-background bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <span class="material-symbols-outlined font-black text-xl">chevron_left</span>
    </button>

    <div class="flex gap-3 font-label-md font-black text-lg">
        @for (int i = 1; i <= TotalPages; i++)
        {
            int pageNum = i;
            if (pageNum == currentPage)
            {
                <button class="w-12 h-12 flex items-center justify-center border-4 border-on-background bg-[#d1b3ff] shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] translate-x-[2px] translate-y-[2px]">@pageNum</button>
            }
            else
            {
                <button @onclick="() => GoToPage(pageNum)" class="w-12 h-12 flex items-center justify-center border-4 border-on-background bg-white hover:bg-[#e7e0e7] transition-colors shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">@pageNum</button>
            }
        }
    </div>

    <button @onclick="NextPage" disabled="@(currentPage == TotalPages)" class="w-12 h-12 flex items-center justify-center border-4 border-on-background bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all disabled:opacity-50 disabled:hover:translate-x-0 disabled:hover:translate-y-0 disabled:hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <span class="material-symbols-outlined font-black text-xl">chevron_right</span>
    </button>
</div>

@if (editingUser != null)
{
    <UserEditModal User="editingUser" OnClose="FecharModal" />
}

@code {
    // --- LÓGICA DE PAGINAÇÃO ---
    private int currentPage = 1;
    private int itemsPerPage = 3;
    private int TotalPages => (int)Math.Ceiling((double)UsersList.Count / itemsPerPage);
    private IEnumerable<ReaderUser> DisplayedUsers => UsersList.Skip((currentPage - 1) * itemsPerPage).Take(itemsPerPage);
    private void PreviousPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }
    private void GoToPage(int pageNum) { currentPage = pageNum; }

    // --- CONTROLE DO MODAL ---
    private ReaderUser? editingUser = null;
    private void AbrirModal(ReaderUser user) => editingUser = user;
    private void FecharModal() => editingUser = null;

    // Dados Mockados para renderizar as cartas
