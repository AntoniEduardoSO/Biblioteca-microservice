@using BibliotecaMicroservice.Models

<style>
    @@keyframes reader-open {
        0% { opacity: 0; transform: scale(0.95) translateY(20px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }
    .animate-reader {
        animation: reader-open 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="fixed inset-0 z-[100] bg-background flex flex-col animate-reader">
    
    <!-- Cabeçalho Superior -->
    <header class="h-20 border-b-4 border-on-background flex justify-between items-center px-4 md:px-8 bg-surface-container-lowest shrink-0">
        <h2 class="font-display-lg text-xl md:text-3xl font-black uppercase tracking-tighter truncate max-w-[50%]">
            @Book.BookTitle
        </h2>
        
        <div class="flex items-center gap-4 md:gap-8">
            <span class="font-label-md font-bold uppercase hidden md:block">
                Página @currentPage de @totalPages
            </span>
            <button @onclick="Fechar" class="bg-[#ffdad6] text-[#93000a] border-2 border-on-background p-2 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[1px_1px_0px_0px_rgba(0,0,0,1)] transition-all flex items-center justify-center">
                <span class="material-symbols-outlined font-black">close</span>
            </button>
        </div>
    </header>

    <!-- Área de Visualização do PDF -->
    <div class="flex-1 overflow-hidden bg-surface-variant flex items-center justify-center p-4 md:p-8 relative bg-grid-pattern bg-grid">
        
        <!-- Botão Voltar -->
        <button @onclick="PrevPage" disabled="@(currentPage == 1)" class="absolute left-2 md:left-8 bg-white border-4 border-on-background p-3 md:p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-secondary-container disabled:opacity-50 disabled:hover:bg-white disabled:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all z-10">
            <span class="material-symbols-outlined font-black">chevron_left</span>
        </button>

        <!-- A PÁGINA EM SI -->
        <div class="h-full w-full max-w-4xl bg-white border-4 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col overflow-y-auto transition-all duration-300">
            @if (currentPage == 1)
            {
                <!-- Página 1: Capa -->
                <img src="@Book.CoverUrl" class="w-full h-full object-cover grayscale mix-blend-multiply opacity-90 p-4" />
            }
            else if (currentPage == 2)
            {
                <!-- Página 2: Lorem Ipsum -->
                <div class="p-8 md:p-16 space-y-6">
                    <h1 class="font-display-lg text-4xl font-black uppercase border-b-4 border-on-background pb-4 mb-8">Capítulo 1</h1>
                    <p class="font-body-lg text-xl leading-relaxed text-on-surface-variant">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
                    <p class="font-body-lg text-xl leading-relaxed text-on-surface-variant">Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
                </div>
            }
            else if (currentPage == 3)
            {
                <!-- Página 3: Fim/Agradecimentos -->
                <div class="p-12 flex flex-col items-center justify-center h-full text-center space-y-8 bg-primary-container">
                    <h1 class="font-display-lg text-[80px] leading-none font-black uppercase text-on-background drop-shadow-[4px_4px_0px_#fff]">FIM</h1>
                    <p class="font-body-lg font-bold text-2xl uppercase border-2 border-on-background bg-white px-6 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">Obrigado por ler @Book.BookTitle!</p>
                </div>
            }
        </div>

        <!-- Botão Avançar -->
        <button @onclick="NextPage" disabled="@(currentPage == totalPages)" class="absolute right-2 md:right-8 bg-white border-4 border-on-background p-3 md:p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-secondary-container disabled:opacity-50 disabled:hover:bg-white disabled:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all z-10">
            <span class="material-symbols-outlined font-black">chevron_right</span>
        </button>

    </div>
</div>

@code {
    [Parameter] public Loan Book { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }
    
    private int currentPage = 1;
    private int totalPages = 3;

    private void NextPage() { if (currentPage < totalPages) currentPage++; }
    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private Task Fechar() => OnClose.InvokeAsync();
}