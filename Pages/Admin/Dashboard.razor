@page "/admin/dashboard"
@layout AdminLayout
@using BibliotecaMicroservice.Models

<style>
    .chart-axis { stroke: #1d1b1f; stroke-width: 2; vector-effect: non-scaling-stroke; }
    
    .chart-line-1 { stroke: #a2ece4; stroke-width: 4; fill: none; stroke-linecap: round; stroke-linejoin: round; vector-effect: non-scaling-stroke; }
    .chart-line-2 { stroke: #ffcba4; stroke-width: 4; fill: none; stroke-linecap: round; stroke-linejoin: round; vector-effect: non-scaling-stroke; }

    .chart-quartile-line { stroke: #ccc4d1; stroke-width: 2; stroke-dasharray: 6 6; vector-effect: non-scaling-stroke; }

    .chart-data-value { fill: #1d1b1f; font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 800; text-anchor: middle; }
    
    .chart-label { fill: #4a454f; font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 600; }
    .label-y { text-anchor: end; }
    .label-x { text-anchor: middle; }
</style>
<header class="mb-10 mt-2 border-b-2 border-on-background pb-6 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
    <div>
        <h1 class="font-display-lg text-[40px] xl:text-[48px] text-on-background tracking-tighter uppercase font-black">Visão Geral</h1>
        <p class="font-body-lg text-on-surface-variant text-xl mt-2">Visão de desempenho e gerenciamento do acervo.</p>
    </div>
    <button class="bg-primary-container border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[3px] hover:translate-y-[3px] transition-all px-6 py-3 font-label-md font-bold uppercase text-on-background flex items-center gap-2">
        <span class="material-symbols-outlined font-bold">download</span> Exportar Dados
    </button>
</header>

<div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
    
    <div class="bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-6">
        <div class="flex justify-between items-start mb-4">
            <h3 class="font-headline-md font-bold text-on-background uppercase tracking-wider text-xs">Total de Aluguéis</h3>
            <div class="bg-surface-lowest border-2 border-on-background p-2">
                <span class="material-symbols-outlined text-on-surface">book_4</span>
            </div>
        </div>
        <div class="font-display-lg text-on-background text-4xl font-black mb-2">4.821</div>
        <div class="flex items-center gap-2">
            <span class="bg-[#ccc460] border-2 border-on-background px-2 py-1 font-label-sm font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">trending_up</span> +12.5%
            </span>
            <span class="font-body-md text-on-surface-variant text-sm">vs mês passado</span>
        </div>
    </div>
    
    <div class="bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-6">
        <div class="flex justify-between items-start mb-4">
            <h3 class="font-headline-md font-bold text-on-background uppercase tracking-wider text-xs">Usuários Ativos</h3>
            <div class="bg-surface-lowest border-2 border-on-background p-2">
                <span class="material-symbols-outlined text-on-surface">group</span>
            </div>
        </div>
        <div class="font-display-lg text-secondary text-4xl font-black mb-2">1.204</div>
        <div class="flex items-center gap-2">
            <span class="bg-surface-bright border-2 border-on-background px-2 py-1 font-label-sm font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">trending_up</span> +5.2%
            </span>
            <span class="font-body-md text-on-surface-variant text-sm">vs mês passado</span>
        </div>
    </div>
    
    <div class="bg-[#ffdad6] border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-6">
        <div class="flex justify-between items-start mb-4">
            <h3 class="font-headline-md font-bold text-[#93000a] uppercase tracking-wider text-xs">Empréstimos Atrasados</h3>
            <div class="bg-surface-container-lowest border-2 border-on-background p-2">
                <span class="material-symbols-outlined text-error font-bold">priority_high</span>
            </div>
        </div>
        <div class="font-display-lg text-[#93000a] text-4xl font-black mb-2">37</div>
        <div class="flex items-center gap-2">
            <span class="bg-surface-bright border-2 border-on-background px-2 py-1 font-label-sm font-bold text-on-background flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">trending_down</span> -2.1%
            </span>
            <span class="font-body-md text-on-surface-variant text-sm">vs mês passado</span>
        </div>
    </div>

    <div class="bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-6">
        <div class="flex justify-between items-start mb-4">
            <h3 class="font-headline-md font-bold text-on-background uppercase tracking-wider text-xs">Tempo Médio (Retorno)</h3>
            <div class="bg-surface-lowest border-2 border-on-background p-2">
                <span class="material-symbols-outlined text-on-surface">schedule</span>
            </div>
        </div>
        <div class="font-display-lg text-tertiary text-4xl font-black mb-2">4.2 <span class="text-xl">dias</span></div>
        <div class="flex items-center gap-2">
            <span class="bg-surface-variant border-2 border-on-background px-2 py-1 font-label-sm font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">trending_flat</span> 0.0%
            </span>
            <span class="font-body-md text-on-surface-variant text-sm">vs mês passado</span>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
    
    <div class="bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-8">
        <div class="flex justify-between items-center mb-8 border-b-2 border-on-background pb-4">
            <div>
                <h2 class="font-headline-lg text-2xl font-bold text-on-background">Aluguéis por Mês</h2>
                <p class="font-body-md text-on-surface-variant mt-1">Trajetória do volume de locações</p>
            </div>
            <div class="flex items-center gap-2">
                <div class="w-4 h-4 bg-[#a2ece4] border-2 border-on-background"></div>
                <span class="font-label-md font-bold uppercase tracking-wider text-xs">Aluguéis</span>
            </div>
        </div>
        <div class="w-full h-[360px] relative mt-4">
            <svg class="w-full h-full overflow-visible" preserveAspectRatio="none" viewBox="0 0 800 360">
                
                <line class="chart-quartile-line" x1="50" x2="780" y1="250" y2="250"></line>
                <line class="chart-quartile-line" x1="50" x2="780" y1="110" y2="110"></line>

                <line class="chart-axis" x1="50" x2="780" y1="320" y2="320"></line>
                <line class="chart-axis" x1="50" x2="50" y1="40" y2="320"></line>
                
                <text class="chart-label label-y" x="40" y="324">0</text>
                <text class="chart-label label-y" x="40" y="254">250</text>
                <text class="chart-label label-y" x="40" y="184">500</text>
                <text class="chart-label label-y" x="40" y="114">750</text>
                <text class="chart-label label-y" x="40" y="44">1000</text>

                <text class="chart-label label-x" x="100" y="345">Jan</text>
                <text class="chart-label label-x" x="230" y="345">Fev</text>
                <text class="chart-label label-x" x="360" y="345">Mar</text>
                <text class="chart-label label-x" x="490" y="345">Abr</text>
                <text class="chart-label label-x" x="620" y="345">Mai</text>
                <text class="chart-label label-x" x="750" y="345">Jun</text>
                
                <polyline class="chart-line-1" points="100,264 230,180 360,250 490,110 620,152 750,54"></polyline>
                
                <text class="chart-data-value" x="100" y="249">200</text>
                <text class="chart-data-value" x="230" y="165">500</text>
                <text class="chart-data-value" x="360" y="235">250</text>
                <text class="chart-data-value" x="490" y="95">750</text>
                <text class="chart-data-value" x="620" y="137">600</text>
                <text class="chart-data-value" x="750" y="39">950</text>
            </svg>
        </div>
    </div>

    <div class="bg-surface-container-lowest border-2 border-on-background shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] p-8">
        <div class="flex justify-between items-center mb-8 border-b-2 border-on-background pb-4">
            <div>
                <h2 class="font-headline-lg text-2xl font-bold text-on-background">Lucro Mensal</h2>
                <p class="font-body-md text-on-surface-variant mt-1">Margens de lucro líquido</p>
            </div>
            <div class="flex items-center gap-2">
                <div class="w-4 h-4 bg-[#ffcba4] border-2 border-on-background"></div>
                <span class="font-label-md font-bold uppercase tracking-wider text-xs">Lucro</span>
            </div>
        </div>
        <div class="w-full h-[360px] relative mt-4">
            <svg class="w-full h-full overflow-visible" preserveAspectRatio="none" viewBox="0 0 800 360">
                
                <line class="chart-quartile-line" x1="50" x2="780" y1="250" y2="250"></line>
                <line class="chart-quartile-line" x1="50" x2="780" y1="110" y2="110"></line>

                <line class="chart-axis" x1="50" x2="780" y1="320" y2="320"></line>
                <line class="chart-axis" x1="50" x2="50" y1="40" y2="320"></line>
                
                <text class="chart-label label-y" x="40" y="324">0</text>
                <text class="chart-label label-y" x="40" y="254">$1.2k</text>
                <text class="chart-label label-y" x="40" y="184">$2.5k</text>
                <text class="chart-label label-y" x="40" y="114">$3.7k</text>
                <text class="chart-label label-y" x="40" y="44">$5.0k</text>

                <text class="chart-label label-x" x="100" y="345">Jan</text>
                <text class="chart-label label-x" x="230" y="345">Fev</text>
                <text class="chart-label label-x" x="360" y="345">Mar</text>
                <text class="chart-label label-x" x="490" y="345">Abr</text>
                <text class="chart-label label-x" x="620" y="345">Mai</text>
                <text class="chart-label label-x" x="750" y="345">Jun</text>
                
                <polyline class="chart-line-2" points="100,230 230,208 360,219 490,107 620,96 750,51"></polyline>
                
                <text class="chart-data-value" x="100" y="215">$1.6k</text>
                <text class="chart-data-value" x="230" y="193">$2.0k</text>
                <text class="chart-data-value" x="360" y="204">$1.8k</text>
                <text class="chart-data-value" x="490" y="92">$3.8k</text>
                <text class="chart-data-value" x="620" y="81">$4.0k</text>
                <text class="chart-data-value" x="750" y="36">$4.8k</text>
            </svg>
        </div>
    </div>
</div>

<div class="bg-surface-container-lowest border-2 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-8 flex flex-col mb-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h3 class="font-headline-md text-2xl font-bold text-on-surface">Gerenciamento de Inventário</h3>
            <p class="font-body-md text-on-surface-variant">Gerencie o catálogo da biblioteca e monitore a saúde do acervo.</p>
        </div>
        <button @onclick="() => AbrirModal(null)" class="bg-primary-container text-on-surface border-2 border-on-background px-6 py-3 font-label-md uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all flex items-center gap-2 font-bold">
            <span class="material-symbols-outlined text-xl">add</span> Novo Livro
        </button>
    </div>
    
    <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="border-b-2 border-on-background">
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Título</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Autor</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">ISBN</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Status</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs text-right">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Books)
                {
                    <tr class="border-b-2 border-on-background hover:bg-surface-variant transition-colors group">
                        <td class="py-5 px-2 font-body-lg font-bold">@item.Title</td>
                        <td class="py-5 px-2 font-body-md text-on-surface-variant text-base">@item.Author</td>
                        <td class="py-5 px-2 font-body-md text-on-surface-variant">@item.ISBN</td>
                        <td class="py-5 px-2">
                            @if (item.Status == BookStatus.Available)
                            {
                                <span class="inline-block bg-[#ccc460] border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase">Disponível</span>
                            }
                            else if (item.Status == BookStatus.Loaned)
                            {
                                <span class="inline-block bg-surface-bright border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase">Emprestado</span>
                            }
                            else
                            {
                                <span class="inline-block bg-[#ffdad6] text-[#93000a] border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase">Atrasado</span>
                            }
                        </td>
                        <td class="py-5 px-2 text-right">
                            <div class="flex items-center justify-end gap-3 opacity-100 xl:opacity-0 xl:group-hover:opacity-100 transition-opacity">
                                <button @onclick="() => AbrirModal(item)" class="p-2 border-2 border-on-background bg-surface-lowest hover:bg-primary-container transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                    <span class="material-symbols-outlined text-xl">edit</span>
                                </button>
                                <button class="p-2 border-2 border-on-background bg-surface-lowest hover:bg-[#ffdad6] text-error transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4 overflow-y-auto">
        <div class="relative w-full max-w-2xl bg-surface border-2 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-8 mt-auto mb-auto">
            
            <button @onclick="FecharModal" class="absolute top-4 right-4 p-2 border-2 border-on-background hover:bg-surface-variant transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                <span class="material-symbols-outlined font-bold">close</span>
            </button>

            <header class="mb-8 border-b-2 border-on-background pb-6 flex items-center justify-between">
                <div>
                    <h1 class="font-headline-lg text-3xl font-black text-on-surface mb-2">
                        @(isEditMode ? "Editar Livro" : "Adicionar Novo Livro")
                    </h1>
                </div>
                <div class="border-2 border-on-background p-3 bg-surface shadow-[4px_4px_0px_0px_#ccc460]">
                    <span class="material-symbols-outlined text-3xl text-on-surface">edit_document</span>
                </div>
            </header>

            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="block font-label-md font-bold uppercase tracking-wider">Título</label>
                    <input type="text" @bind="editingBook.Title" class="w-full bg-white border-2 border-on-background p-3 font-body-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:outline-none focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all" />
                </div>
                <div class="space-y-2">
                    <label class="block font-label-md font-bold uppercase tracking-wider">Autor</label>
                    <input type="text" @bind="editingBook.Author" class="w-full bg-white border-2 border-on-background p-3 font-body-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:outline-none focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block font-label-md font-bold uppercase tracking-wider">ISBN</label>
                        <input type="text" @bind="editingBook.ISBN" class="w-full bg-white border-2 border-on-background p-3 font-body-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:outline-none focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all" />
                    </div>
                    <div class="space-y-2">
                        <label class="block font-label-md font-bold uppercase tracking-wider">Status</label>
                        <select @bind="editingBook.Status" class="w-full bg-white border-2 border-on-background p-3 font-body-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:outline-none focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all appearance-none">
                            <option value="@BookStatus.Available">Disponível</option>
                            <option value="@BookStatus.Loaned">Emprestado</option>
                            <option value="@BookStatus.Overdue">Atrasado</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="flex justify-between items-center pt-8 mt-8 border-t-2 border-on-background">
                @if (isEditMode)
                {
                    <button class="bg-[#ffdad6] text-[#93000a] border-2 border-on-background px-6 py-3 font-bold uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex items-center gap-2 hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">
                        <span class="material-symbols-outlined">delete</span> Apagar
                    </button>
                }
                else { <div></div> }

                <div class="flex gap-4">
                    <button @onclick="FecharModal" class="bg-surface-variant border-2 border-on-background px-6 py-3 font-bold uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">Cancelar</button>
                    <button @onclick="SalvarLivro" class="bg-primary-container border-2 border-on-background px-8 py-3 font-bold uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex gap-2 hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">
                        <span class="material-symbols-outlined">save</span> Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showModal = false;
    private bool isEditMode = false;
    private Book editingBook = new();

    private List<Book> Books = new()
    {
        new Book { Id = 1, Title = "Neuromancer", Author = "William Gibson", ISBN = "978-0441569595", Status = BookStatus.Available },
        new Book { Id = 2, Title = "Snow Crash", Author = "Neal Stephenson", ISBN = "978-0553380958", Status = BookStatus.Loaned },
        new Book { Id = 3, Title = "A Mão Esquerda da Escuridão", Author = "Ursula K. Le Guin", ISBN = "978-0441478125", Status = BookStatus.Available },
        new Book { Id = 4, Title = "Dune", Author = "Frank Herbert", ISBN = "978-0441172719", Status = BookStatus.Overdue }
    };

    private void AbrirModal(Book book)
    {
        if (book == null)
        {
            isEditMode = false;
            editingBook = new Book { Status = BookStatus.Available };
        }
        else
        {
            isEditMode = true;
            editingBook = new Book 
            { 
                Id = book.Id, 
                Title = book.Title, 
                Author = book.Author, 
                ISBN = book.ISBN, 
                Status = book.Status 
            };
        }
        showModal = true;
    }

    private void FecharModal()
    {
        showModal = false;
    }

    private void SalvarLivro()
    {
        showModal = false;
    }
}