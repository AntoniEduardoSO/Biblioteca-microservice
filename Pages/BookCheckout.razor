@layout MainLayout
@using BibliotecaMicroservice.Models

<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4 overflow-y-auto">
    
    <div
        class="w-full max-w-6xl bg-[#FFF8ED] border-2 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative flex flex-col md:flex-row overflow-hidden mt-auto mb-auto">
        
        <button @onclick="FecharModal"
                class="absolute top-6 right-6 z-20 p-2 bg-white border-2 border-on-background hover:bg-[#ffdad6] shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all">
            <span class="material-symbols-outlined font-bold">close</span>
        </button>

        <div
            class="w-full md:w-1/3 bg-primary-container p-8 flex flex-col items-center justify-center border-b-2 md:border-b-0 md:border-r-2 border-on-background">
            <div
                class="w-full max-w-[220px] aspect-[2/3] border-2 border-on-background shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] bg-white mb-6 overflow-hidden relative">
                <img alt="Capa do Livro" class="w-full h-full object-cover" src="@Book.CoverUrl" />
            </div>
            <h2 class="font-headline-lg text-2xl font-black text-center text-on-background leading-tight">@Book.Title
            </h2>
            <p class="font-body-md text-on-surface-variant font-bold mt-2">@Book.Author</p>
            
            <div
                class="mt-8 bg-[#ccc460] border-2 border-on-background px-4 py-1 font-label-sm font-bold uppercase shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                Exemplar Disponível
            </div>
        </div>

        <div
            class="w-full md:w-1/3 p-8 flex flex-col bg-surface border-b-2 md:border-b-0 md:border-r-2 border-on-background">
            <header class="mb-10 flex items-center justify-between">
                <div>
                    <h1 class="font-display-lg text-3xl font-black uppercase tracking-tighter">Checkout</h1>
                    <p class="font-label-sm text-on-surface-variant uppercase font-bold tracking-widest text-[10px]">
                        Configuração de Período</p>
                    </div>
                </header>

                <div class="flex-grow space-y-8">
                    <div class="space-y-3">
                        <label class="block font-label-md font-bold uppercase tracking-wider text-xs">Data de
                            Devolução</label>
                            <input type="date" @bind="ReturnDate"
                                   class="w-full bg-white border-2 border-on-background p-4 font-body-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] focus:outline-none focus:translate-x-[2px] focus:translate-y-[2px] focus:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all" />
                        </div>

                        <div class="space-y-4">
                            <div
                                class="bg-white border-2 border-on-background p-4 flex items-center justify-between shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-on-surface">calendar_today</span>
                                    <span class="font-label-sm font-bold uppercase">Duração</span>
                                </div>
                                <span class="font-body-md font-black text-primary">14 Dias</span>
                            </div>

                            <div
                                class="bg-white border-2 border-on-background p-4 flex items-center justify-between shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-on-surface">payments</span>
                                    <span class="font-label-sm font-bold uppercase">Multa Diária</span>
                                </div>
                                <span class="font-body-md font-black text-error">R$ 2,50</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-1/3 p-8 flex flex-col bg-surface justify-between">
            
                    <div class="flex justify-end pr-16 mt-2">
                        <div
                            class="w-14 h-14 border-2 border-on-background bg-[#ccc460] shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] shrink-0 flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl text-on-background">local_library</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="p-5 border-2 border-on-background border-dashed flex items-center gap-4 bg-surface-bright">
                            <div
                                class="w-12 h-12 bg-secondary-container border-2 border-on-background flex items-center justify-center shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                <span class="material-symbols-outlined text-on-background">account_circle</span>
                            </div>
                            <div>
                                <p class="font-label-sm font-bold leading-none">Antônio Eduardo</p>
                                <p class="font-label-sm text-on-surface-variant text-[10px] uppercase mt-1">Conta Verificada</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 space-y-4">
                        <p class="text-[10px] font-bold text-on-surface-variant leading-tight uppercase tracking-tight">
                            * Ao confirmar, os dados brutos de locação serão processados pelo microsserviço de gestão de acervo.
                        </p>
                        <button
                            class="w-full bg-primary-container border-2 border-on-background py-5 font-display-lg text-xl font-black uppercase shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[4px] active:translate-y-[4px] transition-all flex items-center justify-center gap-3 group">
                            Confirmar Aluguel
                            <span
                            class="material-symbols-outlined font-black group-hover:scale-110 transition-transform">check_circle</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public int BookId { get; set; }
    private DateTime ReturnDate { get; set; } = DateTime.Now.AddDays(14);
    
    // Mock dos dados brutos do livro
    private Book Book = new Book
    {
        Title = "Neuromancer",
        Author = "William Gibson",
        CoverUrl = "https://images.unsplash.com/photo-1618557161755-9ef633e88c0a?q=80&w=600&auto=format&fit=crop"
    };

    private async Task FecharModal()
    {
        await OnClose.InvokeAsync();
    }
}