@inherits LayoutComponentBase

<div class="bg-background text-on-background font-body-md bg-grid-pattern bg-grid min-h-screen flex flex-col">
    
    <header
        class="bg-surface-container-lowest w-full border-b-2 border-on-background flex justify-center h-24 sticky top-0 z-50">
        <div
            class="container mx-auto max-w-container-max flex justify-between items-center h-full px-margin-mobile xl:px-0 gap-8">
        
            <div class="flex items-center h-full w-[260px] shrink-0 border-r-0 xl:border-r-2 border-transparent">
                <span
                    class="font-headline-lg text-[20px] font-black text-on-surface tracking-tight uppercase leading-tight">
                    Projeto de Engenharia<br />de Software
                </span>
            </div>

            <div class="flex-1 relative hidden md:block max-w-2xl">
                <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-2xl">search</span>
                <input
                class="w-full pl-14 pr-6 py-4 bg-surface-container-lowest border-2 border-on-background focus:outline-none focus:ring-2 focus:ring-on-background focus:ring-offset-2 transition-shadow font-body-lg text-body-lg placeholder:text-on-surface-variant neo-shadow"
                placeholder="Pesquisar por título, autor ou ISBN no acervo..." type="text" />
            </div>
        
            <div class="flex items-center gap-4 shrink-0">
                <button
                    class="flex items-center justify-center p-3 border-2 border-on-background bg-surface-container-lowest neo-shadow hover:bg-secondary-container transition-all">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button
                    class="flex items-center justify-center p-3 border-2 border-on-background bg-surface-container-lowest neo-shadow hover:bg-secondary-container transition-all">
                    <span class="material-symbols-outlined">account_circle</span>
                </button>
            
                <button
                    class="hidden lg:block bg-surface-container-lowest border-2 border-on-background px-6 py-3 font-label-md text-label-md font-bold neo-shadow hover:bg-primary-container transition-all text-on-surface">
                    Painel do Usuário
                </button>
            </div>
        </div>
    </header>

    <div
        class="flex flex-1 overflow-hidden relative container mx-auto max-w-container-max mt-6 mb-8 px-margin-mobile xl:px-0 gap-8">
        
        <NavMenu />
        
        <main class="flex-1 flex flex-col min-w-0">
            @Body
        </main>
        
        <aside
            class="hidden xl:block w-[320px] shrink-0 h-fit border-2 border-on-background bg-surface-container-lowest neo-shadow p-6 sticky top-[120px]">
            <h3 class="font-headline-md text-headline-md border-b-2 border-on-background pb-2 mb-4">Empréstimos Rápidos
            </h3>
            <div class="flex flex-col gap-4">
                <div
                    class="flex gap-4 items-start border-2 border-transparent hover:border-on-background p-2 transition-all group">
                    <div
                        class="w-12 h-16 border-2 border-on-background bg-secondary-container shrink-0 flex items-center justify-center">
                        <span class="material-symbols-outlined text-on-background">menu_book</span>
                    </div>
                    <div class="flex-1">
                        <h4
                            class="font-label-md text-label-md leading-tight group-hover:text-primary transition-colors">
                            Minimalismo Digital</h4>
                            <p class="font-label-sm text-label-sm text-error mt-1 font-bold">Atrasado: 01 Out</p>
                        </div>
                    </div>
                </div>
                <button
                    class="w-full mt-6 border-2 border-on-background bg-surface px-4 py-2 font-label-md text-label-md font-bold neo-shadow hover:bg-primary-container transition-all">
                    Ver Todos
                </button>
            </aside>
        </div>
    </div>