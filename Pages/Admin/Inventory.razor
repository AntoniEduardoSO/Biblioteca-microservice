@page "/admin/inventory"
@layout AdminLayout
@using BibliotecaMicroservice.Models

<div class="mb-8 mt-2 border-b-2 border-on-background pb-6">
    <h2 class="font-display-lg text-[40px] xl:text-[48px] text-on-background mb-2 font-black tracking-tight">Inventário</h2>
    <p class="font-body-lg text-on-surface-variant text-xl">Catálogo completo e controle de acervo.</p>
</div>

<div class="bg-surface-container-lowest border-2 border-on-background shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-8 flex flex-col mb-12">
    <div class="flex justify-between items-center mb-8">
        <h3 class="font-headline-md text-2xl font-bold text-on-surface">Gerenciamento de Inventário</h3>
        
        <button @onclick="() => AbrirModal(null)" class="bg-primary-container text-on-surface border-2 border-on-background px-6 py-3 font-label-md uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all flex items-center gap-2 font-bold">
            <span class="material-symbols-outlined text-xl">add</span> Novo Livro
        </button>
    </div>
    
    <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="border-b-2 border-on-background">
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Título</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Autor</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">ISBN</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs">Status</th>
                    <th class="py-4 px-2 font-label-md font-bold uppercase tracking-wider text-xs text-right">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Books)
                {
                    <tr class="border-b-2 border-on-background hover:bg-surface-variant transition-colors group">
                        <td class="py-5 px-2 font-body-lg font-bold text-on-surface">@item.Title</td>
                        <td class="py-5 px-2 font-body-md text-on-surface-variant">@item.Author</td>
                        <td class="py-5 px-2 font-body-md text-on-surface-variant">@item.ISBN</td>
                        <td class="py-5 px-2">
                            @if (item.Status == BookStatus.Available)
                            {
                                <span class="inline-block bg-[#ccc460] border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase text-on-background shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Disponível</span>
                            }
                            else if (item.Status == BookStatus.Loaned)
                            {
                                <span class="inline-block bg-surface-bright border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase text-on-background shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Emprestado</span>
                            }
                            else
                            {
                                <span class="inline-block bg-[#ffdad6] text-[#93000a] border-2 border-on-background px-3 py-1 font-label-sm font-bold uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Atrasado</span>
                            }
                        </td>
                        <td class="py-5 px-2 text-right">
                            <div class="flex items-center justify-end gap-3 opacity-100 xl:opacity-0 xl:group-hover:opacity-100 transition-opacity">
                                <button @onclick="() => AbrirModal(item)" class="p-2 border-2 border-on-background bg-surface-lowest hover:bg-primary-container transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                    <span class="material-symbols-outlined text-xl">edit</span>
                                </button>
                                <button class="p-2 border-2 border-on-background bg-surface-lowest hover:bg-[#ffdad6] text-error transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showModal)
{
   <BookForm BookId="editingBook?.Id" OnClose="FecharModal" />
}

@code {
    private bool showModal = false;
    private bool isEditMode = false;
    private InventoryItem editingBook = new();

    private List<InventoryItem> Books = new()
    {
        new InventoryItem { Id = 1, Title = "Neuromancer", Author = "William Gibson", ISBN = "978-0441569595", Status = BookStatus.Available },
        new InventoryItem { Id = 2, Title = "Snow Crash", Author = "Neal Stephenson", ISBN = "978-0553380958", Status = BookStatus.Loaned },
        new InventoryItem { Id = 3, Title = "A Mão Esquerda da Escuridão", Author = "Ursula K. Le Guin", ISBN = "978-0441478125", Status = BookStatus.Available },
        new InventoryItem { Id = 4, Title = "Dune", Author = "Frank Herbert", ISBN = "978-0441172719", Status = BookStatus.Overdue }
    };

    private void AbrirModal(InventoryItem book)
    {
        editingBook = book;
        showModal = true;
    }

    private void FecharModal()
    {
        showModal = false;
    }

    public class InventoryItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public string ISBN { get; set; } = "";
        public BookStatus Status { get; set; }
    }

    public enum BookStatus
    {
        Available,
        Loaned,
        Overdue
    }
}